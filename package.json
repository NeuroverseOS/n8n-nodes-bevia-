{
  "name": "n8n-nodes-bevia",
  "version": "0.1.0",
  "description": "Bevia community node \u2014 read the map of your thinking (territories, changes, landmarks, daily pulse), query it, export it, poll for map-change events, send content in, and file observations. A coordination wire for a person or an AI agent. Targets n8n.",
  "license": "MIT",
  "homepage": "https://github.com/NeuroverseOS/n8n-nodes-bevia-",
  "author": {
    "name": "Bevia",
    "url": "https://bevia.co"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NeuroverseOS/n8n-nodes-bevia-.git"
  },
  "keywords": [
    "n8n-community-node-package",
    "bevia",
    "map",
    "territories",
    "coordination",
    "polling",
    "ai-agent"
  ],
  "engines": {
    "node": ">=18.10"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-icons.mjs",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/BeviaApi.credentials.js",
      "dist/credentials/BeviaLocalEngine.credentials.js"
    ],
    "nodes": [
      "dist/nodes/BeviaTrigger/BeviaTrigger.node.js",
      "dist/nodes/Bevia/Bevia.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "n8n-workflow": "^1.40.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
